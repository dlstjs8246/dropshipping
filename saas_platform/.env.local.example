# ============================================================
# Supabase — Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ============================================================
# Drizzle — Project Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 6543) for the app.
# Use the "Session" pooler URL (port 5432) for `db:migrate` if needed.
# ============================================================
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ============================================================
# BYOK encryption — random 32-byte hex string
# Generate with: openssl rand -hex 32
# (Used in W3 to encrypt user-supplied Anthropic API keys at rest.)
# ============================================================
ENCRYPTION_KEY=replace-with-32-byte-hex-string-from-openssl-rand
